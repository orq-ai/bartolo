package main

import (
	"github.com/orq-ai/bartolo/cli"
)

func main() {
	cli.Init(&cli.Config{
		AppName:             "{{ .Name }}",
		EnvPrefix:           "{{ .NameEnv }}",
		APIKeyEnvVar:        "{{ .APIKeyEnvVar }}",
		DefaultOutputFormat: "{{ .DefaultOutputFormat }}",
		Version:             "1.0.0",
	})

	registerGeneratedCommands()
	registerCustomCommands()

	cli.Root.Execute()
}
