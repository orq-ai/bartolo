SHELL := /bin/sh
.DEFAULT_GOAL := help

BINARY := {{ .CommandName }}
BIN_DIR ?= ./bin
INSTALL_DIR ?= $(HOME)/.local/bin

.PHONY: help build install-local tidy doctor

help:
	@printf '%s\n' \
		'Available targets:' \
		'  make build          Build ./bin/$(BINARY)' \
		'  make install-local  Install $(BINARY) into $(INSTALL_DIR)' \
		'  make tidy           Run go mod tidy' \
		'  make doctor         Run the CLI doctor command'

build:
	@mkdir -p "$(BIN_DIR)"
	@go build -o "$(BIN_DIR)/$(BINARY)" .
	@printf 'Built %s\n' "$(BIN_DIR)/$(BINARY)"

install-local:
	@mkdir -p "$(INSTALL_DIR)"
	@go build -o "$(INSTALL_DIR)/$(BINARY)" .
	@printf 'Installed %s to %s/%s\n' "$(BINARY)" "$(INSTALL_DIR)" "$(BINARY)"

tidy:
	@go mod tidy

doctor:
	@go run . --json doctor
